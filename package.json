{
  "name": "ruyi-big-screen",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint . --ext .vue,.js,.jsx,.ts,.tsx --fix",
    "lint:style": "stylelint \"src/**/*.{css,vue}\" --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,vue,css,json}\"",
    "type-check": "vue-tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "vue": "^3.5.13",
    "pinia": "^2.3.0",
    "echarts": "^5.6.0",
    "axios": "^1.7.9"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/tsconfig": "^0.7.0",
    "typescript": "~5.7.3",
    "vite": "^6.2.4",
    "vue-tsc": "^2.2.8",
    "@types/node": "^22.13.0",
    "vitest": "^3.1.1",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^26.0.0",
    "@playwright/test": "^1.51.0",
    "msw": "^2.7.3",
    "eslint": "^9.22.0",
    "@eslint/js": "^9.22.0",
    "eslint-plugin-vue": "^9.33.0",
    "typescript-eslint": "^8.27.0",
    "vue-eslint-parser": "^9.4.3",
    "prettier": "^3.5.3",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.5",
    "stylelint": "^16.15.0",
    "stylelint-config-standard": "^37.0.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0"
  },
  "lint-staged": {
    "*.{ts,tsx,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,vue}": [
      "stylelint --fix"
    ],
    "*.{css,json,md}": [
      "prettier --write"
    ]
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
